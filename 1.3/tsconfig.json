{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "lib": ["DOM", "ESNext"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
